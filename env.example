# ============================================
# KINTUADI ENERGY - CONFIGURAÇÕES (EXEMPLO)
# ============================================

# 🔐 CREDENCIAIS ONS (obrigatórias para dados históricos)
# Obtenha em: https://sintegre.ons.org.br/paginas/acesso.aspx
ONS_USERNAME=seu_email@dominio.com
ONS_PASSWORD=sua_senha_segura

# 🌐 URLs DAS APIS
ONS_PUBLIC_API_URL=https://integra.ons.org.br/api
CCEE_API_URL=https://dadosabertos.ccee.org.br/api/3/action

# 📁 DIRETÓRIOS
DATA_DIR=data
LOG_DIR=logs
AUDIT_DIR=audit_logs

# ⏱️ CONFIGURAÇÕES DE CACHE (minutos)
CACHE_TTL_ONS=30
CACHE_TTL_CCEE=60

# 📊 LIMITES DE DADOS
MAX_RESERVATORIOS=100000
MAX_PLD_RECORDS=500000
MAX_HISTORICAL_DAYS=365

# 📝 LOGGING
LOG_LEVEL=INFO

# 🚀 PERFORMANCE
REQUEST_TIMEOUT_SECONDS=30
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=5

# 🌐 CONFIGURAÇÕES DO DASHBOARD
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
STREAMLIT_THEME_BASE=dark